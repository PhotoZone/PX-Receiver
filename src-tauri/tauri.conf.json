{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "PX Receiver",
  "version": "0.3.3",
  "identifier": "com.px.receiver",
  "build": {
    "beforeDevCommand": "npm run dev:web",
    "beforeBuildCommand": "npm run build:sidecar && npm run build:web",
    "devUrl": "http://localhost:3000",
    "frontendDist": "../apps/desktop/out"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "PX Receiver",
        "width": 1750,
        "height": 960,
        "resizable": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "createUpdaterArtifacts": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": [
      "../apps/desktop/public/drivers/CH34x_Install_Windows_v3_4.EXE"
    ],
    "externalBin": [
      "binaries/px-worker"
    ]
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://github.com/PhotoZone/PX-Receiver/releases/latest/download/latest.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEIyMzAzQzYyRDE4RTk4NTkKUldSWm1JN1JZand3c2gzcUU3U3RMcG84cytETHhxUW83bjBEekhNQ1U5TjR0SFRPTFNaMnh1YlAK"
    }
  }
}
