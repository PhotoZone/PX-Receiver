{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "PX Receiver",
  "version": "0.2.0",
  "identifier": "com.px.receiver",
  "build": {
    "beforeDevCommand": "npm run dev:web",
    "beforeBuildCommand": "npm run build:sidecar && npm run build:web",
    "devUrl": "http://localhost:3000",
    "frontendDist": "../apps/desktop/out"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "PX Receiver",
        "width": 1460,
        "height": 960,
        "resizable": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": [
      "../apps/desktop/public/drivers/CH34x_Install_Windows_v3_4.EXE"
    ],
    "externalBin": [
      "binaries/px-worker"
    ]
  }
}
